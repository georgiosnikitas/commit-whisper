{
  "name": "commit-sage",
  "version": "1.0.0",
  "description": "Deterministic git history analysis with a grounded, BYOK AI narrative — terminal-native CLI.",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/georgiosnikitas/commit-sage.git"
  },
  "keywords": [
    "git",
    "metrics",
    "cli",
    "code-analysis",
    "repository-health"
  ],
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/georgiosnikitas/commit-sage/issues"
  },
  "homepage": "https://github.com/georgiosnikitas/commit-sage#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.84",
    "@ai-sdk/google": "3.0.82",
    "@ai-sdk/openai": "3.0.71",
    "@ai-sdk/openai-compatible": "2.0.50",
    "@clack/prompts": "1.5.1",
    "ai": "6.0.203",
    "commander": "15.0.0",
    "picocolors": "1.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "eslint": "10.5.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  }
}
