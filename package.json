{
  "name": "commit-whisper",
  "version": "1.0.7",
  "description": "Deterministic git history analysis with a grounded, BYOK AI narrative — terminal-native CLI.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "commit-whisper": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "bundle:sea": "tsup --config tsup.sea.config.ts",
    "build:sea": "node scripts/build-sea.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/georgiosnikitas/commit-whisper.git"
  },
  "keywords": [
    "git",
    "metrics",
    "cli",
    "code-analysis",
    "repository-health"
  ],
  "author": "Georgios Nikitas <georgiosnikitas@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/georgiosnikitas/commit-whisper/issues"
  },
  "homepage": "https://github.com/georgiosnikitas/commit-whisper#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.85",
    "@ai-sdk/google": "3.0.83",
    "@ai-sdk/openai": "3.0.72",
    "@ai-sdk/openai-compatible": "2.0.51",
    "@clack/prompts": "1.5.1",
    "ai": "6.0.207",
    "commander": "15.0.0",
    "picocolors": "1.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
